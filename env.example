# ─────────────────────────────────────────────
#  Flowvity — Email / SMTP Configuration
#  Copy this file to ".env" and fill in values
# ─────────────────────────────────────────────

# ── Gmail (recommended) ──────────────────────
# Enable 2-Factor Auth on your Google account,
# then create an App Password at:
#   https://myaccount.google.com/apppasswords
# Use that 16-char password as SMTP_PASS.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Flowvity <you@gmail.com>"

# ── Outlook / Hotmail ─────────────────────────
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false

# ── Custom SMTP (Mailgun, SendGrid, etc.) ─────
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=postmaster@mg.yourdomain.com
# SMTP_PASS=your-mailgun-smtp-password
